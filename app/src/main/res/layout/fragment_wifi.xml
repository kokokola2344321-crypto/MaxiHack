<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/wifi_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Ready"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/attack_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_spinner" />

        <ListView
            android:id="@+id/wifi_list"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/ssid_input"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:hint="SSID"
            android:background="@drawable/bg_input" />

        <EditText
            android:id="@+id/password_input"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:background="@drawable/bg_input" />

        <Button
            android:id="@+id/btn_scan"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Scan WiFi"
            android:background="@drawable/btn_primary" />

        <Button
            android:id="@+id/btn_connect"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:text="Connect"
            android:background="@drawable/btn_primary" />

        <Button
            android:id="@+id/btn_create_ap"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:text="Create AP"
            android:background="@drawable/btn_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_beacon"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Beacon Spam"
                android:background="@drawable/btn_attack"
                android:layout_marginRight="4dp" />

            <Switch
                android:id="@+id/switch_beacon"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_deauth"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Deauth Flood"
                android:background="@drawable/btn_attack"
                android:layout_marginRight="4dp" />

            <Switch
                android:id="@+id/switch_deauth"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center" />

        </LinearLayout>

        <EditText
            android:id="@+id/target_input"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:hint="Target IP"
            android:background="@drawable/bg_input" />

        <EditText
            android:id="@+id/port_input"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:hint="Port"
            android:inputType="number"
            android:background="@drawable/bg_input" />

        <Button
            android:id="@+id/btn_scan_hosts"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:text="Scan Hosts"
            android:background="@drawable/btn_primary" />

        <EditText
            android:id="@+id/evil_portal_html"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="8dp"
            android:hint="Evil Portal HTML"
            android:gravity="top"
            android:background="@drawable/bg_input" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_evil_portal"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Evil Portal"
                android:background="@drawable/btn_attack"
                android:layout_marginRight="4dp" />

            <Switch
                android:id="@+id/switch_evil_portal"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_tcp_server"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:text="TCP Server"
            android:background="@drawable/btn_primary" />

        <Button
            android:id="@+id/btn_tcp_client"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:text="TCP Client"
            android:background="@drawable/btn_primary" />

    </LinearLayout>
</ScrollView>
</write_to_file>